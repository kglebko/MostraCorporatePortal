@model CorporatePortal.AuthServer.Models.LoginViewModel
    @{
    ViewData["Title"] = "Вход в систему";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Корпоративный портал</title>

    <style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'TT Travels', Arial, sans-serif;
    background: #ffffff;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
}

.login-container {
    background: #fff;
    border-radius: 15px;
    border: 1px solid #dfdfdf;
    box-shadow: 0 0 6px rgba(0, 0, 0, 0.08);
    width: 100%;
    max-width: 460px;
    padding: 40px;
}

.login-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 30px;
}

.logo {
    height: 48px;
    object-fit: contain;
}

.login-header h1 {
    font-size: 22px;
    color: #002b45;
}

.login-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.input-wrapper {
    position: relative;
}

.form-control {
    width: 100%;
    padding: 12px 16px;
    padding-right: 45px;
    border: 1px solid #dfdfdf;
    border-radius: 50px;
    font-size: 14px;
    transition: 0.3s;
    font-family: 'TT Travels';
}

.form-control:focus {
    outline: none;
    border: 1px solid #f67001;
    box-shadow: 0 0 2px 2px rgba(246, 112, 1, 0.1);
}

.password-toggle {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    cursor: pointer;
    width: 20px;
    height: 20px;
}

.login-options {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
}

.remember-me {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #3f4d58;
    cursor: pointer;
    user-select: none;
}

.remember-me input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    width: 16px;
    height: 16px;
    border: 1.5px solid #dfdfdf;
    border-radius: 4px;
    background: #fff;
    cursor: pointer;
    position: relative;
    transition: all 0.25s ease;
}

.remember-me input[type="checkbox"]:checked {
    background: #f67001;
    border-color: #f67001;
}

.remember-me input[type="checkbox"]::after {
    content: "";
    position: absolute;
    inset: 0;
    background: no-repeat center;
    background-size: 11px;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='%23ffffff' stroke-width='4' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Cpolyline points='20 6 9 17 4 12'/%3E%3C/svg%3E");
    transform: scale(0);
    transition: transform 0.2s ease;
}

.remember-me input[type="checkbox"]:checked::after {
    transform: scale(1);
}

.forgot-link {
    text-decoration: none;
    color: #3f4d58;
    transition: 0.4s ease-in-out;
}

.forgot-link:hover {
    color: #f67001;
    transform: translateY(-2px);
    transition: 0.4s ease-in-out;
}

.btn-login {
    padding: 12px 32px;
    align-self: center;
    background: #f67001;
    color: white;
    border: none;
    border-radius: 50px;
    font-size: 16px;
    cursor: pointer;
    font-family: 'TT Travels';
    transition: 0.4s ease-in-out;
}

.btn-login:hover {
    transform: translateY(-2px);
    transition: 0.4s ease-in-out;
}

.validation-summary{
    color: #f67001;
    font-weight: 500;
    margin: 1rem;
}

</style>
</head>

<body>
<div class="login-container">

    <div class="login-header">
        <img class="logo" src="/icons/logo.svg" />
        <h1>Корпоративный портал</h1>
    </div>

    @if (!string.IsNullOrEmpty(Model?.Error))
    {
    <div class="validation-summary">
        @Model.Error
    </div>
    }

    <form method="post" asp-action="Login" asp-controller="Account" class="login-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ReturnUrl" value="@Model?.ReturnUrl" />

        <div class="form-group">
            <div class="input-wrapper">
                <input type="text"
                       name="Username"
                       class="form-control"
                       placeholder="Логин"
                       required />
            </div>

            <div class="input-wrapper">
                <input type="password"
                       id="Password"
                       name="Password"
                       class="form-control"
                       placeholder="Пароль"
                       required />

                <img id="togglePassword"
                     class="password-toggle"
                     src="/icons/hide_password_icon.svg"
                     alt="toggle password" />
            </div>
        </div>

        <div class="login-options">
            <div class="remember-me">
                <input type="checkbox"
                       id="RememberLogin"
                       name="RememberLogin"
                       value="true"
                       @(Model?.RememberLogin == true ? "checked" : "") />
                <label for="RememberLogin">Запомнить меня</label>
            </div>

            <a href="/account/forgot-password" class="forgot-link">
                Забыли пароль?
            </a>
        </div>

        <button type="submit" class="btn-login">
            Войти
        </button>
    </form>
</div>

<script>
const passwordInput = document.getElementById("Password");
const toggleIcon = document.getElementById("togglePassword");

toggleIcon.addEventListener("click", function () {

    if (passwordInput.type === "password") {
        passwordInput.type = "text";
        toggleIcon.src = "/icons/show_password_icon.svg";
    } else {
        passwordInput.type = "password";
        toggleIcon.src = "/icons/hide_password_icon.svg";
    }

});
</script>
</body>
</html>